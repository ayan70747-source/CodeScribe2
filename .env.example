# Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Required for Flask session signing
FLASK_SECRET_KEY=replace_with_a_long_random_secret

# Admin credentials used by the login form
APP_ADMIN_USERNAME=admin
# Generate with Python:
# from werkzeug.security import generate_password_hash
# print(generate_password_hash("your-strong-password"))
APP_ADMIN_PASSWORD_HASH=replace_with_password_hash

# Comma-separated allowlist for browser origins
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Runtime tuning
MODEL_TIMEOUT_SECONDS=60
FLASK_DEBUG=false
PORT=8080
SESSION_COOKIE_SECURE=false
